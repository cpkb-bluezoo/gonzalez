<project name='gonzalez' default='dist'>

  <property name='src' location='src'/>
  <property name='build' location='build'/>
  <property name='dist' location='dist'/>
  <property name='gumdrop.home' location='../gumdrop'/>
  <property name='gumdrop.jar' location='${gumdrop.home}/dist/server.jar'/>
  
  <!-- Gonzalez version -->
  <property name='version' value='0.1.0'/>
  <property name='gonzalez.jar' location='${dist}/gonzalez-${version}.jar'/>

  <!-- Clean build artifacts -->
  <target name='clean'>
    <delete dir='${build}'/>
    <delete dir='${dist}'/>
  </target>

  <!-- Compile core parser (no Gumdrop dependency) -->
  <target name='build-core'>
    <mkdir dir='${build}'/>
    <javac srcdir='${src}' destdir='${build}' debug='true' includeantruntime='false'>
      <include name='org/bluezoo/gonzalez/*.java'/>
      <include name='org/bluezoo/gonzalez/dtd/*.java'/>
      <exclude name='org/bluezoo/gonzalez/http/*.java'/>
    </javac>
  </target>

  <!-- Compile HTTP entity resolver (requires Gumdrop) -->
  <target name='build-http' depends='build-core'>
    <available file='${gumdrop.jar}' property='gumdrop.present'/>
    <fail unless='gumdrop.present' 
          message='Gumdrop not found. Build Gumdrop first or set gumdrop.home property.'/>
    
    <javac srcdir='${src}' destdir='${build}' debug='true' includeantruntime='false'>
      <classpath>
        <pathelement location='${gumdrop.jar}'/>
        <pathelement location='${build}'/>
      </classpath>
      <include name='org/bluezoo/gonzalez/http/*.java'/>
    </javac>
  </target>

  <!-- Build everything -->
  <target name='build' depends='build-core,build-http'/>

  <!-- Create JAR file -->
  <target name='jar' depends='build'>
    <mkdir dir='${dist}'/>
    <jar destfile='${gonzalez.jar}' basedir='${build}'>
      <manifest>
        <attribute name='Implementation-Title' value='Gonzalez XML Parser'/>
        <attribute name='Implementation-Version' value='${version}'/>
        <attribute name='Implementation-Vendor' value='Chris Burdess'/>
      </manifest>
    </jar>
  </target>

  <!-- Distribution target -->
  <target name='dist' depends='jar'/>

</project>

